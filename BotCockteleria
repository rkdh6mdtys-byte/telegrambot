🍇 Подбор вин
Подбор вина под меню и бюджет.
"""
        kb = types.InlineKeyboardMarkup()
        kb.add(types.InlineKeyboardButton("📝 Оставить заявку", callback_data="request"))
        kb.add(types.InlineKeyboardButton("⬅️ Назад", callback_data="menu"))
        bot.edit_message_text(text, cid, call.message.message_id, reply_markup=kb)

    elif call.data == "prices":
        kb = types.InlineKeyboardMarkup()
        kb.add(types.InlineKeyboardButton("🥉 Стандарт — 65 000 ₽", callback_data="pkg_std"))
        kb.add(types.InlineKeyboardButton("🥈 Бизнес — 100 000 ₽", callback_data="pkg_bus"))
        kb.add(types.InlineKeyboardButton("🥇 Премиум — 125 000 ₽", callback_data="pkg_prem"))
        kb.add(types.InlineKeyboardButton("⬅️ Назад", callback_data="menu"))
        bot.edit_message_text("💰 Выберите пакет", cid, call.message.message_id, reply_markup=kb)

    elif call.data.startswith("pkg_"):
        cards = {
            "pkg_std":"🥉 Стандарт\n\n👨‍🍳 1 бармен\n👥 До 30 гостей\n🍸 До 100 коктейлей\n💰 65 000 ₽",
            "pkg_bus":"🥈 Бизнес\n\n👨‍🍳 1 бармен\n👥 До 100 гостей\n🍸 До 200 коктейлей\n💰 100 000 ₽",
            "pkg_prem":"🥇 Премиум\n\n👨‍🍳👨‍🍳 2 бармена\n👥 100+ гостей\n🍸 200+ коктейлей\n🥃 Настойки\n🥤 Лимонады\n💰 125 000 ₽"
        }
        kb = types.InlineKeyboardMarkup()
        kb.add(types.InlineKeyboardButton("📝 Оставить заявку", callback_data="request"))
        kb.add(types.InlineKeyboardButton("⬅️ Назад", callback_data="prices"))
        bot.edit_message_text(cards[call.data], cid, call.message.message_id, reply_markup=kb)

    elif call.data == "reviews":
        text = """⭐ Отзывы

⭐⭐⭐⭐⭐ Александр
Барная зона стала центром внимания.

⭐⭐⭐⭐⭐ Марина
