            kb.add(types.InlineKeyboardButton(t, callback_data=d))
        kb.add(types.InlineKeyboardButton("⬅️ Назад", callback_data="menu"))
        bot.edit_message_text("🎉 Наши услуги", cid, call.message.message_id, reply_markup=kb)

    elif call.data == "coffee":
        kb = types.InlineKeyboardMarkup()
        kb.add(types.InlineKeyboardButton("☕ Стандарт — 35 000 ₽", callback_data="coffee_std"))
        kb.add(types.InlineKeyboardButton("☕ Премиум — 60 000 ₽", callback_data="coffee_prem"))
        kb.add(types.InlineKeyboardButton("⬅️ Назад", callback_data="services"))
        bot.edit_message_text("☕ Кофе-брейки", cid, call.message.message_id, reply_markup=kb)

    elif call.data == "wine":
        text = """🍷 Винные мероприятия

