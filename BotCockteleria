🍷 Винные дегустации
🎲 Винное казино

📍 Владивосток

Нажмите кнопку ниже."""

def main_menu():
    kb = types.InlineKeyboardMarkup(row_width=2)
    buttons = [
        ("🎉 Услуги","services"),
        ("🍸 Коктейльная карта","cocktails"),
        ("🍷 Винные мероприятия","wine"),
        ("💰 Стоимость","prices"),
        ("📄 Презентация","presentation"),
        ("📸 Наши работы","works"),
        ("⭐ Отзывы","reviews"),
        ("📝 Оставить заявку","request"),
        ("👨‍💼 Менеджер","manager"),
    ]
    for t,d in buttons:
        kb.add(types.InlineKeyboardButton(t, callback_data=d))
    return kb

@bot.message_handler(commands=['start'])
def start(message):
    kb = types.InlineKeyboardMarkup()
    kb.add(types.InlineKeyboardButton("📋 Открыть меню", callback_data="menu"))
    bot.send_message(message.chat.id, WELCOME, reply_markup=kb)

@bot.callback_query_handler(func=lambda c: True)
def callbacks(call):
    cid = call.message.chat.id

    if call.data == "menu":
        bot.edit_message_text("📋 Главное меню", cid, call.message.message_id, reply_markup=main_menu())

    elif call.data == "services":
        kb = types.InlineKeyboardMarkup(row_width=2)
        for t,d in [
            ("💍 Свадьбы","srv_wedding"),
