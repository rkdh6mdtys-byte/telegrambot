            f"👨‍💼 Менеджер\n\nTelegram: {MANAGER_USERNAME}",
            cid, call.message.message_id, reply_markup=kb)

    elif call.data == "request":
        user_data[cid] = {}
        user_state[cid] = "service"
        bot.send_message(cid, "🎉 Укажите услугу (например: Свадьба)")

@bot.message_handler(content_types=['text'])
def form(message):
    cid = message.chat.id
    state = user_state.get(cid)

    if state == "service":
        user_data[cid]["service"] = message.text
        user_state[cid] = "guests"
        bot.send_message(cid, "👥 Сколько гостей?")

    elif state == "guests":
        user_data[cid]["guests"] = message.text
        user_state[cid] = "name"
        bot.send_message(cid, "👤 Как вас зовут?")

    elif state == "name":
        user_data[cid]["name"] = message.text
        user_state[cid] = "date"
        bot.send_message(cid, "📅 Дата мероприятия?")

    elif state == "date":
        user_data[cid]["date"] = message.text
        kb = types.ReplyKeyboardMarkup(resize_keyboard=True, one_time_keyboard=True)
        kb.add(types.KeyboardButton("📱 Отправить контакт", request_contact=True))
        user_state[cid] = "contact"
        bot.send_message(cid, "Нажмите кнопку ниже", reply_markup=kb)

@bot.message_handler(content_types=['contact'])
def contact(message):
    cid = message.chat.id
    if cid not in user_data:
        return

    text = f"""🚨 НОВАЯ ЗАЯВКА

🎉 Услуга: {user_data[cid]['service']}
👥 Гостей: {user_data[cid]['guests']}
👤 Имя: {user_data[cid]['name']}
📅 Дата: {user_data[cid]['date']}
📱 Телефон: {message.contact.phone_number}
"""
    bot.send_message(ADMIN_ID, text)
    bot.send_message(cid, "✅ Заявка отправлена.")
    user_data.pop(cid, None)
    user_state.pop(cid, None)

print("ВОЛНЫ запущен")
bot.infinity_polling()
